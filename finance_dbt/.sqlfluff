[sqlfluff]
templater = jinja
dialect = redshift

[sqlfluff:templater:jinja:macros]
ref = {% macro ref(model_name) %}{{ model_name }}{% endmacro %}
source = {% macro source(source_name, table_name) %}{{ source_name }}_{{ table_name }}{% endmacro %}
config = {% macro config(**kwargs) %}{% endmacro %}
is_incremental = {% macro is_incremental() %}false{% endmacro %}